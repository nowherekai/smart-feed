# Runtime
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_feed
DATABASE_SSL=false

# Queue
REDIS_URL=redis://localhost:6379

# App
PORT=3000
SMART_FEED_TIME_WINDOW_HOURS=72
SMART_FEED_TIMEZONE=Asia/Shanghai
SMART_FEED_DIGEST_TIMEZONE=Asia/Shanghai
SMART_FEED_DIGEST_SEND_HOUR=8
SMART_FEED_DIGEST_MAX_LOOKBACK_HOURS=48
SMART_FEED_VALUE_SCORE_THRESHOLD=6
ANTHROPIC_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

