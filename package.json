{
  "name": "smart-feed",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "next dev",
    "dev:worker": "bun --watch src/workers/index.ts",
    "worker": "bun src/workers/index.ts",
    "build:web": "next build",
    "build:worker": "bun build ./src/workers/index.ts --target bun --outdir dist/worker",
    "build": "bun run build:web && bun run build:worker",
    "start": "next start",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "check": "biome check --write .",
    "ci": "biome ci . && bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.49",
    "@base-ui/react": "^1.3.0",
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/turndown": "^5.0.6",
    "ai": "^6.0.141",
    "bullmq": "^5.71.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.5.9",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.7.0",
    "marked": "^16.4.1",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.6",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rss-parser": "^3.13.0",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "turndown": "^7.2.2",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "^1.3.11",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.8",
    "typescript": "^6"
  }
}
