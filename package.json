{
  "name": "smart-feed",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "next dev",
    "dev:worker": "bun --watch src/workers/index.ts",
    "worker": "bun src/workers/index.ts",
    "build:web": "next build",
    "build:worker": "bun build ./src/workers/index.ts --target bun --outdir dist/worker",
    "build": "bun run build:web && bun run build:worker",
    "start": "next start",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "check": "biome check --write .",
    "ci": "biome ci . && bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.49",
    "@types/turndown": "^5.0.6",
    "ai": "^6.0.141",
    "bullmq": "^5.71.1",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.5.9",
    "ioredis": "^5.10.1",
    "linkedom": "^0.18.12",
    "next": "^16.2.1",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rss-parser": "^3.13.0",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/bun": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.8",
    "typescript": "^6"
  }
}
